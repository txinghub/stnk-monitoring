   333|// Update timestamp terakhir
   334|function updateLastUpdate(timestamp) {
   335|    const date = new Date(timestamp);
   336|    const formatted = date.toLocaleString('id-ID', {
   337|        year: 'numeric',
   338|        month: 'long',
   339|        day: 'numeric',
   340|        hour: '2-digit',
   341|        minute: '2-digit',
   342|        second: '2-digit'
   343|    });
   344|    document.getElementById('lastUpdate').textContent = formatted;
