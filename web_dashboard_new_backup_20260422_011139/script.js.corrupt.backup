   196|// Update charts
   197|function updateCharts(stats, data) {
   198|    // Status Distribution Chart (Pie)
   199|    const statusCtx = document.getElementById('statusChart').getContext('2d');
   200|    
   201|    if (statusChart) {
   202|        statusChart.destroy();
   203|    }
   204|    
   205|    statusChart = new Chart(statusCtx, {
   206|        type: 'pie',
   207|        data: {
   208|            labels: ['AMAN', 'PERINGATAN', 'PRIORITAS'],
   209|            datasets: [{
   210|                data: [stats.safe, stats.warning, stats.priority],
   211|                backgroundColor: [
   212|                    'rgba(40, 167, 69, 0.8)',
   213|                    'rgba(255, 193, 7, 0.8)',
   214|                    'rgba(220, 53, 69, 0.8)'
   215|                ],
   216|                borderColor: [
   217|                    'rgb(40, 167, 69)',
   218|                    'rgb(255, 193, 7)',
   219|                    'rgb(220, 53, 69)'
   220|                ],
   221|                borderWidth: 1
   222|            }]
   223|        },
   224|        options: {
   225|            responsive: true,
   226|            maintainAspectRatio: false,
   227|            plugins: {
   228|                legend: {
   229|                    position: 'bottom',
   230|                    labels: {
   231|                        padding: 20,
   232|                        font: {
   233|                            size: 12
   234|                        }
   235|                    }
   236|                },
   237|                tooltip: {
   238|                    callbacks: {
   239|                        label: function(context) {
   240|                            const label = context.label || '';
   241|                            const value = context.raw || 0;
   242|                            const total = context.dataset.data.reduce((a, b) => a + b, 0);
   243|                            const percentage = Math.round((value / total) * 100);
   244|                            return `${label}: ${value} (${percentage}%)`;
   245|                        }
   246|                    }
   247|                }
   248|            }
   249|        }
   250|    });
   251|
   252|    // Days to Expiry Chart (Bar)
   253|    const daysCtx = document.getElementById('daysChart').getContext('2d');
   254|    const vehicleNames = data.map(v => v.merk.substring(0, 15) + (v.merk.length > 15 ? '...' : ''));
   255|    const daysData = data.map(v => v.hari_menuju_jatuh_tempo);
   256|    const backgroundColors = data.map(v => {
   257|        switch(v.status) {
   258|            case 'safe': return 'rgba(40, 167, 69, 0.7)';
   259|            case 'warning': return 'rgba(255, 193, 7, 0.7)';
   260|            case 'priority': return 'rgba(220, 53, 69, 0.7)';
   261|            default: return 'rgba(108, 117, 125, 0.7)';
   262|        }
   263|    });
   264|
   265|    if (daysChart) {
   266|        daysChart.destroy();
   267|    }
   268|
   269|    daysChart = new Chart(daysCtx, {
   270|        type: 'bar',
   271|        data: {
   272|            labels: vehicleNames,
   273|            datasets: [{
   274|                label: 'Hari Menuju Jatuh Tempo',
   275|                data: daysData,
   276|                backgroundColor: backgroundColors,
   277|                borderColor: backgroundColors.map(color => color.replace('0.7', '1')),
   278|                borderWidth: 1
   279|            }]
   280|        },
   281|        options: {
   282|            responsive: true,
   283|            maintainAspectRatio: false,
   284|            scales: {
   285|                y: {
   286|                    beginAtZero: true,
   287|                    title: {
   288|                        display: true,
   289|                        text: 'Hari'
   290|                    },
   291|                    ticks: {
   292|                        callback: function(value) {
   293|                            return value + ' hari';
   294|                        }
   295|                    }
   296|                },
   297|                x: {
   298|                    ticks: {
   299|                        maxRotation: 45,
   300|                        minRotation: 45
   301|                    }
   302|                }
   303|            },
   304|            plugins: {
   305|                legend: {
   306|                    display: false
   307|                },
   308|                tooltip: {
   309|                    callbacks: {
   310|                        label: function(context) {
   311|                            return `${context.dataset.label}: ${context.raw} hari`;
   312|                        }
   313|                    }
   314|                }
   315|            }
   316|        }
   317|    });
   318|}
