   100|// Update tabel DataTables
   101|function updateTable(data) {
   102|    const tableBody = document.getElementById('vehicleTableBody');
   103|    tableBody.innerHTML = '';
   104|
   105|    data.forEach(vehicle => {
   106|        const row = document.createElement('tr');
   107|        
   108|        // Tentukan class baris berdasarkan status
   109|        let rowClass = '';
   110|        switch(vehicle.status) {
   111|            case 'priority': rowClass = 'table-danger'; break;
   112|            case 'warning': rowClass = 'table-warning'; break;
   113|            case 'safe': rowClass = 'table-success'; break;
   114|        }
   115|        row.className = rowClass;
   116|
   117|        // Format hari dengan warna
   118|        let daysHtml = '';
   119|        if (vehicle.hari_menuju_jatuh_tempo <= 0) {
   120|            daysHtml = `<span class="badge bg-danger">TELAH JATUH TEMPO</span>`;
   121|        } else if (vehicle.hari_menuju_jatuh_tempo <= 30) {
   122|            daysHtml = `<span class="text-danger fw-bold">${vehicle.hari_menuju_jatuh_tempo} hari</span>`;
   123|        } else if (vehicle.hari_menuju_jatuh_tempo <= 90) {
   124|            daysHtml = `<span class="text-warning fw-bold">${vehicle.hari_menuju_jatuh_tempo} hari</span>`;
   125|        } else {
   126|            daysHtml = `<span class="text-success">${vehicle.hari_menuju_jatuh_tempo} hari</span>`;
   127|        }
   128|
   129|        row.innerHTML = `
   130|            <td>${vehicle.id}</td>
   131|            <td><strong>${vehicle.merk}</strong></td>
   132|            <td><code>${vehicle.no_polisi}</code></td>
   133|            <td>${vehicle.kategori}</td>
   134|            <td>${formatDate(vehicle.stnk_date)}</td>
   135|            <td>${formatDate(vehicle.pajak_date)}</td>
   136|            <td>${daysHtml}</td>
   137|            <td>
   138|                <span class="status-badge status-${vehicle.status}">
   139|                    ${getStatusText(vehicle.status)}
   140|                </span>
   141|            </td>
   142|            <td>${vehicle.ktp}</td>
   143|            <td>${vehicle.catatan || '-'}</td>
   144|        `;
   145|
   146|        tableBody.appendChild(row);
   147|    });
   148|
   149|    // Inisialisasi atau refresh DataTables
   150|    if (dataTable) {
   151|        dataTable.destroy();
   152|    }
   153|    
   154|    dataTable = $('#vehicleTable').DataTable({
   155|        pageLength: 10,
   156|        lengthMenu: [5, 10, 25, 50],
   157|        order: [[6, 'asc']], // Urutkan berdasarkan hari menuju jatuh tempo
   158|        columnDefs: [
   159|            { width: '50px', targets: 0 }, // No
   160|            { width: '150px', targets: 2 }, // No Polisi - diperlebar
   161|            { width: '100px', targets: 3 }, // Kategori
   162|            { width: '120px', targets: 4 }, // Tanggal STNK
   163|            { width: '120px', targets: 5 }, // Tanggal Pajak
   164|            { width: '150px', targets: 6 }, // Hari Menuju Jatuh Tempo
   165|            { width: '120px', targets: 7 }, // Status
   166|            { width: '150px', targets: 8 }, // Pemilik
   167|            { width: '200px', targets: 9 }, // Catatan
   168|            { 
   169|                responsivePriority: 1, 
   170|                targets: [0, 1, 2, 3, 6, 7] // Kolom penting untuk mobile
   171|            },
   172|            { 
   173|                responsivePriority: 2, 
   174|                targets: [4, 5] // Kolom tanggal
   175|            },
   176|            { 
   177|                responsivePriority: 3, 
   178|                targets: [8, 9] // Kolom kurang penting (Pemilik, Catatan)
   179|            }
   180|        ],
   181|        responsive: true,
   182|        language: {
   183|            search: "Cari:",
   184|            lengthMenu: "Tampilkan _MENU_ data",
   185|            info: "Menampilkan _START_ sampai _END_ dari _TOTAL_ data",
   186|            paginate: {
   187|                first: "Pertama",
   188|                last: "Terakhir",
   189|                next: "Berikutnya",
   190|                previous: "Sebelumnya"
   191|            }
   192|        }
   193|    });
   194|}
