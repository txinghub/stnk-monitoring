     1|// Dashboard STNK Monitoring - Main JavaScript
     2|let vehiclesData = [];
     3|let statusChart = null;
     4|let daysChart = null;
     5|let dataTable = null;
     6|
     7|// Format tanggal untuk tampilan
     8|function formatDate(dateString) {
     9|    if (!dateString) return '-';
    10|    const date = new Date(dateString);
    11|    return date.toLocaleDateString('id-ID', {
    12|        year: 'numeric',
    13|        month: 'long',
    14|        day: 'numeric'
    15|    });
    16|}
    17|
    18|// Hitung hari menuju jatuh tempo
    19|function calculateDaysToExpiry(expiryDate) {
    20|    const today = new Date();
    21|    const expiry = new Date(expiryDate);
    22|    const diffTime = expiry - today;
    23|    const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24));
    24|    return diffDays;
    25|}
    26|
    27|// Tentukan status berdasarkan hari
    28|function getStatus(days) {
    29|    if (days <= 30) return 'priority';
    30|    if (days <= 90) return 'warning';
    31|    return 'safe';
    32|}
    33|
    34|// Tentukan warna status
    35|function getStatusColor(status) {
    36|    switch(status) {
    37|        case 'safe': return 'success';
    38|        case 'warning': return 'warning';
    39|        case 'priority': return 'danger';
    40|        default: return 'secondary';
    41|    }
    42|}
    43|
    44|// Tentukan teks status
    45|function getStatusText(status) {
    46|    switch(status) {
    47|        case 'safe': return 'AMAN';
    48|        case 'warning': return 'PERINGATAN';
    49|        case 'priority': return 'PRIORITAS';
    50|        default: return 'TIDAK DIKETAHUI';
    51|    }
    52|}
    53|
    54|// Ambil data dari API
    55|async function fetchData() {
    56|    try {
    57|        const response = await fetch('/api/data');
    58|        const data = await response.json();
    59|        
    60|        if (data.success) {
    61|            vehiclesData = data.vehicles;
    62|            updateDashboard(vehiclesData);
    63|            updateLastUpdate(data.timestamp);
    64|        } else {
    65|            console.error('Error fetching data:', data.error);
    66|            showError('Gagal memuat data: ' + data.error);
    67|        }
    68|    } catch (error) {
    69|        console.error('Fetch error:', error);
    70|        showError('Gagal terhubung ke server. Pastikan server berjalan.');
    71|    }
    72|}
    73|
    74|// Update dashboard dengan data baru
    75|function updateDashboard(data) {
    76|    // Hitung statistik
    77|    const stats = {
    78|        safe: data.filter(v => v.status === 'safe').length,
    79|        warning: data.filter(v => v.status === 'warning').length,
    80|        priority: data.filter(v => v.status === 'priority').length,
    81|        total: data.length
    82|    };
    83|
    84|    // Update summary cards
    85|    document.getElementById('safeCount').textContent = stats.safe;
    86|    document.getElementById('warningCount').textContent = stats.warning;
    87|    document.getElementById('priorityCount').textContent = stats.priority;
    88|    document.getElementById('totalCount').textContent = stats.total;
    89|
    90|    // Update tabel
    91|    updateTable(data);
    92|
    93|    // Update chart
    94|    updateCharts(stats, data);
    95|
    96|    // Update modal dropdown
    97|    updateVehicleSelect(data);
    98|}
