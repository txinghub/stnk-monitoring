   347|// Submit update form
   348|async function submitUpdate() {
   349|    const vehicleId = document.getElementById('vehicleSelect').value;
   350|    const newStnkDate = document.getElementById('newStnkDate').value;
   351|    const newPajakDate = document.getElementById('newPajakDate').value;
   352|    const updateNote = document.getElementById('updateNote').value;
   353|
   354|    if (!vehicleId || !newStnkDate || !newPajakDate) {
   355|        showError('Harap isi semua field yang wajib diisi.');
   356|        return;
   357|    }
   358|
   359|    try {
   360|        const response = await fetch('/api/update', {
   361|            method: 'POST',
   362|            headers: {
   363|                'Content-Type': 'application/json',
   364|            },
   365|            body: JSON.stringify({
   366|                vehicleId: parseInt(vehicleId),
   367|                newStnkDate,
   368|                newPajakDate,
   369|                note: updateNote
   370|            })
   371|        });
   372|
   373|        const result = await response.json();
   374|        
   375|        if (result.success) {
   376|            showSuccess('Data berhasil diupdate!');
   377|            // Tutup modal
   378|            const modal = bootstrap.Modal.getInstance(document.getElementById('updateModal'));
   379|            modal.hide();
   380|            // Reset form
   381|            document.getElementById('updateForm').reset();
   382|            // Refresh data
   383|            setTimeout(fetchData, 1000);
   384|        } else {
   385|            showError('Gagal update data: ' + result.error);
   386|        }
   387|    } catch (error) {
   388|        console.error('Update error:', error);
   389|        showError('Gagal mengirim update ke server.');
   390|    }
   391|}
