   474|// ============================================
   475|// FUNGSI TAMBAH KENDARAAN BARU
   476|// ============================================
   477|
   478|function submitAddVehicle() {
   479|    const merk = document.getElementById('addMerk').value.trim();
   480|    const noPolisi = document.getElementById('addNoPolisi').value.trim();
   481|    const kategori = document.getElementById('addKategori').value;
   482|    const pemilik = document.getElementById('addPemilik').value.trim();
   483|    const stnkDate = document.getElementById('addStnkDate').value;
   484|    const pajakDate = document.getElementById('addPajakDate').value;
   485|    const catatan = document.getElementById('addCatatan').value.trim();
   486|
   487|    // Validasi
   488|    if (!merk || !noPolisi || !kategori || !stnkDate || !pajakDate) {
   489|        alert('Harap isi semua field yang wajib diisi (*)');
   490|        return;
   491|    }
   492|
   493|    // Konfirmasi
   494|    if (!confirm(`Tambahkan kendaraan baru?\nMerk: ${merk}\nNo Polisi: ${noPolisi}`)) {
   495|        return;
   496|    }
   497|
   498|    // Hitung hari menuju jatuh tempo
   499|    const today = new Date();
   500|    const pajakDateObj = new Date(pajakDate);
   501|    const daysToExpiry = Math.ceil((pajakDateObj - today) / (1000 * 60 * 60 * 24));
   502|    
   503|    // Tentukan status
   504|    let status = 'AMAN';
   505|    let statusColor = 'success';
   506|    if (daysToExpiry <= 30) {
   507|        status = 'PERINGATAN';
   508|        statusColor = 'warning';
   509|    }
   510|    if (daysToExpiry <= 15) {
   511|        status = 'PRIORITAS';
   512|        statusColor = 'danger';
   513|    }
   514|    if (daysToExpiry < 0) {
   515|        status = 'TERLAMBAT';
   516|        statusColor = 'dark';
   517|    }
   518|
   519|    // Format tanggal untuk display
   520|    const formatDate = (dateStr) => {
   521|        const date = new Date(dateStr);
   522|        const options = { day: 'numeric', month: 'long', year: 'numeric' };
   523|        return date.toLocaleDateString('id-ID', options);
   524|    };
   525|
   526|    // Buat object kendaraan baru
   527|    const newVehicle = {
   528|        id: Date.now(), // ID unik berdasarkan timestamp
   529|        merk: merk,
   530|        no_polisi: noPolisi,
   531|        kategori: kategori,
   532|        pemilik: pemilik || '-',
   533|        tanggal_stnk: stnkDate,
   534|        tanggal_pajak: pajakDate,
   535|        catatan: catatan || '-',
   536|        hari_menuju_jatuh_tempo: daysToExpiry,
   537|        status: status,
   538|        status_color: statusColor,
   539|        display_stnk: formatDate(stnkDate),
   540|        display_pajak: formatDate(pajakDate)
   541|    };
   542|
   543|    // Kirim data ke server
   544|    fetch('/api/add-vehicle', {
   545|        method: 'POST',
   546|        headers: {
   547|            'Content-Type': 'application/json',
   548|        },
   549|        body: JSON.stringify(newVehicle)
   550|    })
   551|    .then(response => response.json())
   552|    .then(data => {
   553|        if (data.success) {
   554|            // Reset form
   555|            document.getElementById('addVehicleForm').reset();
   556|            
   557|            // Tutup modal
   558|            const modal = bootstrap.Modal.getInstance(document.getElementById('addVehicleModal'));
   559|            modal.hide();
   560|            
   561|            // Tampilkan notifikasi sukses
   562|            showNotification('success', 'Kendaraan berhasil ditambahkan!');
   563|            
   564|            // Refresh data table
   565|            setTimeout(() => {
   566|                if (typeof loadData === 'function') {
   567|                    loadData();
   568|                }
   569|                if (typeof updateCharts === 'function') {
   570|                    updateCharts();
   571|                }
   572|            }, 500);
   573|        } else {
   574|            alert('Gagal menambahkan kendaraan: ' + (data.error || 'Unknown error'));
   575|        }
   576|    })
   577|    .catch(error => {
   578|        console.error('Error:', error);
   579|        alert('Terjadi kesalahan saat menambahkan kendaraan');
   580|    });
   581|}
   582|
   583|// Fungsi untuk menampilkan notifikasi
   584|function showNotification(type, message) {
   585|    // Buat elemen notifikasi
   586|    const notification = document.createElement('div');
   587|    notification.className = `alert alert-${type} alert-dismissible fade show position-fixed`;
   588|    notification.style.cssText = 'top: 20px; right: 20px; z-index: 9999; min-width: 300px;';
   589|    notification.innerHTML = `
   590|        <strong>${type === 'success' ? '✓' : '⚠'}</strong> ${message}
   591|        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
   592|    `;
   593|    
   594|    // Tambahkan ke body
   595|    document.body.appendChild(notification);
   596|    
   597|    // Auto-hide setelah 3 detik
   598|    setTimeout(() => {
   599|        if (notification.parentNode) {
   600|            notification.remove();
   601|        }
   602|    }, 3000);
   603|}
   604|
   605|// Reset form ketika modal ditutup
   606|document.addEventListener('DOMContentLoaded', function() {
   607|    const addVehicleModal = document.getElementById('addVehicleModal');
   608|    if (addVehicleModal) {
   609|        addVehicleModal.addEventListener('hidden.bs.modal', function() {
   610|            document.getElementById('addVehicleForm').reset();
   611|        });
   612|    }
   613|});
