   320|// Update dropdown di modal
   321|function updateVehicleSelect(data) {
   322|    const select = document.getElementById('vehicleSelect');
   323|    select.innerHTML = '<option value="">Pilih kendaraan...</option>';
   324|    
   325|    data.forEach(vehicle => {
   326|        const option = document.createElement('option');
   327|        option.value = vehicle.id;
   328|        option.textContent = `${vehicle.merk} (${vehicle.no_polisi}) - ${getStatusText(vehicle.status)}`;
   329|        select.appendChild(option);
   330|    });
