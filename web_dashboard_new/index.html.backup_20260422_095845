<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MONITORING STNK & PAJAK</title>
    
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
    <!-- jQuery (required for DataTables) -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <!-- Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <!-- DataTables -->
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/responsive/2.5.0/css/responsive.bootstrap5.min.css">
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>
    <script src="https://cdn.datatables.net/responsive/2.5.0/js/dataTables.responsive.min.js"></script>
    <script src="https://cdn.datatables.net/responsive/2.5.0/js/responsive.bootstrap5.min.js"></script>
    
    <style>
        :root {
            --safe-color: #28a745;
            --warning-color: #ffc107;
            --priority-color: #dc3545;
        }
        
        body {
            background-color: #f8f9fa;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }
        
        .navbar-brand {
            font-weight: 700;
            font-size: 1.5rem;
        }
        
        .card {
            border-radius: 10px;
            box-shadow: 0 4px 6px rgba(0,0,0,0.1);
            border: none;
            margin-bottom: 20px;
        }
        
        .card-header {
            background-color: #fff;
            border-bottom: 2px solid #e9ecef;
            font-weight: 600;
        }
        
        .status-badge {
            padding: 5px 12px;
            border-radius: 20px;
            font-weight: 600;
            font-size: 0.85rem;
        }
        
        .status-safe {
            background-color: rgba(40, 167, 69, 0.1);
            color: var(--safe-color);
            border: 1px solid rgba(40, 167, 69, 0.3);
        }
        
        .status-warning {
            background-color: rgba(255, 193, 7, 0.1);
            color: var(--warning-color);
            border: 1px solid rgba(255, 193, 7, 0.3);
        }
        
        .status-priority {
            background-color: rgba(220, 53, 69, 0.1);
            color: var(--priority-color);
            border: 1px solid rgba(220, 53, 69, 0.3);
        }
        
        .table-hover tbody tr:hover {
            background-color: rgba(0, 0, 0, 0.02);
        }
        
        .chart-container {
            position: relative;
            height: 300px;
            width: 100%;
        }
        
        .summary-card {
            text-align: center;
            padding: 20px;
        }
        
        .summary-icon {
            font-size: 2.5rem;
            margin-bottom: 10px;
        }
        
        .summary-count {
            font-size: 2rem;
            font-weight: 700;
            margin-bottom: 5px;
        }
        
        .summary-label {
            color: #6c757d;
            font-size: 0.9rem;
        }
        
        .btn-update {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            border: none;
            color: white;
            font-weight: 600;
            padding: 10px 20px;
            border-radius: 8px;
            transition: all 0.3s ease;
        }
        
        .btn-update:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(0,0,0,0.2);
        }
        
        /* Tombol aksi di tabel */
        .btn-action {
            padding: 4px 8px;
            font-size: 0.85rem;
            margin: 2px;
            border-radius: 4px;
        }
        
        .btn-delete {
            background-color: #dc3545;
            color: white;
            border: none;
        }
        
        .btn-delete:hover {
            background-color: #c82333;
        }
        
        .btn-update-small {
            background-color: #17a2b8;
            color: white;
            border: none;
        }
        
        .btn-update-small:hover {
            background-color: #138496;
        }
        
        .aksi-buttons {
            display: flex;
            gap: 5px;
            flex-wrap: wrap;
            justify-content: center;
        }
        
        /* Kolom Aksi di tabel */
        #vehicleTable th:nth-child(11),
        #vehicleTable td:nth-child(11) {
            min-width: 120px;
            max-width: 150px;
            text-align: center;
        }
        
        .modal-header {
            background-color: #f8f9fa;
            border-bottom: 2px solid #e9ecef;
        }
        
        .form-label {
            font-weight: 600;
            color: #495057;
        }
        
        .form-control:focus {
            border-color: #667eea;
            box-shadow: 0 0 0 0.25rem rgba(102, 126, 234, 0.25);
        }
        
        footer {
            background-color: #343a40;
            color: white;
            padding: 20px 0;
            margin-top: 40px;
        }
        
        /* Fix untuk kolom No Polisi - tidak wrap dan lebar cukup */
        #vehicleTable td:nth-child(3),
        #vehicleTable th:nth-child(3) {
            min-width: 120px;
            max-width: 150px;
            white-space: nowrap;
        }
        
        /* Style untuk kode nomor polisi - DIPERBESAR */
        #vehicleTable td:nth-child(3) code {
            background-color: #f8f9fa;
            padding: 4px 8px;
            border-radius: 4px;
            border: 1px solid #dee2e6;
            font-family: 'Courier New', monospace;
            font-weight: bold;
            font-size: 1.1rem; /* DIPERBESAR dari default */
            color: #212529; /* Warna lebih gelap */
            display: inline-block;
        }
        
        /* Untuk header No Polisi juga diperbesar */
        #vehicleTable th:nth-child(3) {
            font-size: 1rem;
            font-weight: 700;
        }
        
        @media (max-width: 768px) {
            .navbar-brand {
                font-size: 1.2rem;
            }
            
            .summary-count {
                font-size: 1.5rem;
            }
            
            .chart-container {
                height: 250px;
            }
            
            /* Responsive table adjustments */
            #vehicleTable td:nth-child(3),
            #vehicleTable th:nth-child(3) {
                min-width: 100px;
                max-width: 130px;
            }
            
            /* Hide less important columns on mobile */
            #vehicleTable td:nth-child(9), /* Pemilik */
            #vehicleTable th:nth-child(9),
            #vehicleTable td:nth-child(10), /* Catatan */
            #vehicleTable th:nth-child(10) {
                display: none;
            }
        }
        
        @media (max-width: 576px) {
            /* Further adjustments for very small screens */
            #vehicleTable td:nth-child(3),
            #vehicleTable th:nth-child(3) {
                min-width: 90px;
                max-width: 110px;
                font-size: 0.9rem;
            }
            
            #vehicleTable td:nth-child(3) code {
                padding: 3px 6px;
                font-size: 1rem; /* DIPERBESAR dari 0.85rem */
            }
        }
    </style>
</head>
<body>
    <!-- Navigation -->
    <nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm">
        <div class="container">
            <a class="navbar-brand" href="#">
                <i class="bi bi-car-front-fill me-2"></i>
                MONITORING STNK & PAJAK
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a class="nav-link active" href="#"><i class="bi bi-speedometer2 me-1"></i> Dashboard</a>
                    </li>
                    <li class="nav-item">
                        <button class="btn btn-success ms-2" data-bs-toggle="modal" data-bs-target="#addVehicleModal">
                            <i class="bi bi-plus-circle me-1"></i> TAMBAH KENDARAAN
                        </button>
                    </li>
                    <li class="nav-item">
                        <button class="btn btn-update ms-2" data-bs-toggle="modal" data-bs-target="#updateModal">
                            <i class="bi bi-arrow-clockwise me-1"></i> UPDATE SETELAH BAYAR
                        </button>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <div class="container mt-4">
        <!-- Summary Cards -->
        <div class="row mb-4">
            <div class="col-md-3">
                <div class="card summary-card">
                    <div class="summary-icon text-success">
                        <i class="bi bi-check-circle-fill"></i>
                    </div>
                    <div class="summary-count" id="safeCount">0</div>
                    <div class="summary-label">AMAN</div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card summary-card">
                    <div class="summary-icon text-warning">
                        <i class="bi bi-exclamation-triangle-fill"></i>
                    </div>
                    <div class="summary-count" id="warningCount">0</div>
                    <div class="summary-label">PERINGATAN</div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card summary-card">
                    <div class="summary-icon text-danger">
                        <i class="bi bi-exclamation-octagon-fill"></i>
                    </div>
                    <div class="summary-count" id="priorityCount">0</div>
                    <div class="summary-label">PRIORITAS</div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card summary-card">
                    <div class="summary-icon text-primary">
                        <i class="bi bi-car-front-fill"></i>
                    </div>
                    <div class="summary-count" id="totalCount">0</div>
                    <div class="summary-label">TOTAL KENDARAAN</div>
                </div>
            </div>
        </div>

        <!-- Charts -->
        <div class="row mb-4">
            <div class="col-md-6">
                <div class="card">
                    <div class="card-header">
                        <i class="bi bi-pie-chart-fill me-2"></i> Distribusi Status
                    </div>
                    <div class="card-body">
                        <div class="chart-container">
                            <canvas id="statusChart"></canvas>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card">
                    <div class="card-header">
                        <i class="bi bi-bar-chart-fill me-2"></i> Hari Menuju Jatuh Tempo
                    </div>
                    <div class="card-body">
                        <div class="chart-container">
                            <canvas id="daysChart"></canvas>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Data Table -->
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <div>
                    <i class="bi bi-table me-2"></i> Data Monitoring Kendaraan
                </div>
                <div>
                    <button class="btn btn-sm btn-outline-primary me-2" onclick="refreshData()">
                        <i class="bi bi-arrow-clockwise"></i> Refresh
                    </button>
                    <button class="btn btn-sm btn-outline-success" onclick="exportToExcel()">
                        <i class="bi bi-file-earmark-excel"></i> Export Excel
                    </button>
                </div>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table id="vehicleTable" class="table table-hover" style="width:100%">
                        <thead>
                            <tr>
                                <th>No</th>
                                <th>Merk Kendaraan</th>
                                <th>No Polisi</th>
                                <th>Kategori</th>
                                <th>Tanggal STNK</th>
                                <th>Tanggal Pajak</th>
                                <th>Hari Menuju Jatuh Tempo</th>
                                <th>Status</th>
                                <th>Pemilik</th>
                                <th>Catatan</th>
                                <th>Aksi</th>
                            </tr>
                        </thead>
                        <tbody id="vehicleTableBody">
                            <!-- Data akan diisi oleh JavaScript -->
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- Update Modal -->
    <div class="modal fade" id="updateModal" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        <i class="bi bi-arrow-clockwise me-2"></i> Update Data Setelah Bayar
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <form id="updateForm">
                        <div class="mb-3">
                            <label class="form-label">Kendaraan yang dipilih:</label>
                            <div class="alert alert-info" id="selectedVehicleInfo">
                                Pilih kendaraan dari dropdown atau klik tombol "Update" di tabel
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Pilih Kendaraan (dropdown)</label>
                            <select class="form-select" id="vehicleSelect" required onchange="updateSelectedVehicleInfo()">
                                <option value="">Pilih kendaraan...</option>
                                <!-- Options akan diisi oleh JavaScript -->
                            </select>
                        </div>
                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">Tanggal STNK Baru</label>
                                    <input type="date" class="form-control" id="newStnkDate" required>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">Tanggal Pajak Baru</label>
                                    <input type="date" class="form-control" id="newPajakDate" required>
                                </div>
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Catatan Update</label>
                            <textarea class="form-control" id="updateNote" rows="3" placeholder="Tambahkan catatan jika perlu..."></textarea>
                        </div>
                        <div class="alert alert-info">
                            <i class="bi bi-info-circle me-2"></i>
                            Setelah update, status kendaraan akan berubah menjadi "AMAN" dan warna akan berubah menjadi hijau.
                        </div>
                    </form>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Batal</button>
                    <button type="button" class="btn btn-update" onclick="submitUpdate()">
                        <i class="bi bi-check-circle me-1"></i> Update Data
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Add Vehicle Modal -->
    <div class="modal fade" id="addVehicleModal" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header bg-success text-white">
                    <h5 class="modal-title">
                        <i class="bi bi-plus-circle me-2"></i> Tambah Kendaraan Baru
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <form id="addVehicleForm">
                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">Merk Kendaraan <span class="text-danger">*</span></label>
                                    <input type="text" class="form-control" id="addMerk" placeholder="Contoh: HONDA NF" required>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">No Polisi <span class="text-danger">*</span></label>
                                    <input type="text" class="form-control" id="addNoPolisi" placeholder="Contoh: BK 1234 ABC" required>
                                    <small class="text-muted">Format: BK 1234 ABC (gunakan spasi)</small>
                                </div>
                            </div>
                        </div>
                        
                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">Kategori <span class="text-danger">*</span></label>
                                    <select class="form-select" id="addKategori" required>
                                        <option value="">Pilih kategori...</option>
                                        <option value="Roda Dua">Roda Dua</option>
                                        <option value="Roda Tiga">Roda Tiga</option>
                                        <option value="Roda Empat">Roda Empat</option>
                                        <option value="Truk">Truk</option>
                                        <option value="Bus">Bus</option>
                                    </select>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">Pemilik</label>
                                    <input type="text" class="form-control" id="addPemilik" placeholder="Nama pemilik kendaraan">
                                </div>
                            </div>
                        </div>
                        
                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">Tanggal STNK <span class="text-danger">*</span></label>
                                    <input type="date" class="form-control" id="addStnkDate" required>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">Tanggal Pajak <span class="text-danger">*</span></label>
                                    <input type="date" class="form-control" id="addPajakDate" required>
                                </div>
                            </div>
                        </div>
                        
                        <div class="mb-3">
                            <label class="form-label">Catatan</label>
                            <textarea class="form-control" id="addCatatan" rows="2" placeholder="Tambahkan catatan jika perlu..."></textarea>
                        </div>
                        
                        <div class="alert alert-info">
                            <i class="bi bi-info-circle me-2"></i>
                            Data akan langsung ditambahkan ke sistem dan muncul di tabel monitoring.
                        </div>
                    </form>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Batal</button>
                    <button type="button" class="btn btn-success" onclick="submitAddVehicle()">
                        <i class="bi bi-check-circle me-1"></i> Simpan Kendaraan
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Footer -->
    <footer>
        <div class="container text-center">
            <p class="mb-0">
                <i class="bi bi-shield-check me-1"></i> 
                Sistem Monitoring STNK & Pajak v1.0 • 
                <span id="currentYear"></span>
            </p>
            <small class="text-muted">
                Terakhir update: <span id="lastUpdate"></span>
            </small>
        </div>
    </footer>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    
    <!-- Main JavaScript -->
    <script src="script.js"></script>
</body>
</html>